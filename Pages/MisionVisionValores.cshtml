@page
@{
    ViewData["Title"] = "Misión, Visión y Valores";
}

<section class="panel">
    <h2>Misión, Visión y Valores</h2>
    <div class="card-grid two-col">
        <article class="card">
            <h3>Misión</h3>
            <p>
                Proporcionar soluciones de transferencia segura de archivos que protejan la confidencialidad de la información
                sensible mediante criptografía de clase empresarial y cumplimiento riguroso de estándares internacionales.
            </p>
        </article>
        <article class="card">
            <h3>Visión</h3>
            <p>
                Ser una plataforma de referencia para transferencia cifrada de archivos en entornos corporativos, reconocida por
                su enfoque de seguridad por diseño, auditabilidad y modelo de claves efímeras.
            </p>
        </article>
    </div>
    <div class="card-grid four-col">
        <article class="card">
            <h3>Confidencialidad</h3>
            <p>Los archivos solo pueden abrirse por usuarios autorizados.</p>
        </article>
        <article class="card">
            <h3>Integridad</h3>
            <p>Las descargas se validan para detectar manipulación.</p>
        </article>
        <article class="card">
            <h3>Disponibilidad</h3>
            <p>Acceso oportuno a archivos protegidos y auditables.</p>
        </article>
        <article class="card">
            <h3>Minimización</h3>
            <p>Las claves temporales existen solo el tiempo necesario.</p>
        </article>
    </div>
</section>