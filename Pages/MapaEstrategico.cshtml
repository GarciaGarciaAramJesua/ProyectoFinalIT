@page
@{
    ViewData["Title"] = "Mapa Estratégico - SecureTransfer";
}

<section class="panel">
    <h2>Mapa Estratégico Corporativo</h2>
    <p>
        El mapa estratégico corporativo visualiza las iniciativas y estrategias específicas 
        para alcanzar cada meta corporativa, articulando las acciones clave en cada dimensión 
        del Balanced Scorecard.
    </p>
    <figure class="diagram-block" id="diagrama-corporativo">
        <img src="/images/MapaEstrategicoCorporativo.png"
             alt="Mapa Estratégico Corporativo — Balanced Scorecard"
             class="diagram-img"
             onerror="this.closest('figure').classList.add('no-img')" />
        <figcaption>
            Mapa Estratégico Corporativo — Balanced Scorecard
            <br /><span class="diagram-path">wwwroot/images/MapaEstrategicoCorporativo.png</span>
        </figcaption>
    </figure>
</section>

<section class="panel">
    <h3>Estrategias Corporativas por Dimensión</h3>
    
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Dimensión</th>
                    <th>Estrategias</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong>Financiera</strong></td>
                    <td>Reducir costos de producción en un 5% para el segundo trimestre del año 2026.</td>
                </tr>
                <tr>
                    <td><strong>Cliente/Usuario</strong></td>
                    <td>
                        <ul class="bullet-list">
                            <li>1. Trasladar lo ahorrado en los procesos, para una muestra de precios más atractivos</li>
                            <li>2. Posicionar a la empresa como un proveedor verde y responsable</li>
                            <li>3. Promover mediante el área de mercadotecnia el concepto de eficiencia con recursos y costos optimizados</li>
                            <li>4. Mejorar el tiempo de respuesta en soporte</li>
                            <li>5. Promover un programa de fidelización para el cliente, como newsletter</li>
                        </ul>
                    </td>
                </tr>
                <tr>
                    <td><strong>Interno/Procesos</strong></td>
                    <td>
                        <ul class="bullet-list">
                            <li>1. Recortar licencias que puedan ser de uso compartido o multiusuario</li>
                            <li>2. Obtener recursos con el mínimo gasto posible en las áreas que lo permitan</li>
                            <li>3. Proponer horarios para el prendido y apagado del aire acondicionado a partir de ciertas horas</li>
                            <li>4. Implementar un sistema de energía que autorregule el consumo</li>
                            <li>5. Optimización de flujos de trabajo</li>
                        </ul>
                    </td>
                </tr>
                <tr>
                    <td><strong>Aprendizaje y Crecimiento</strong></td>
                    <td>
                        <ul class="bullet-list">
                            <li>1. Implementar un modelo de home office en las áreas que lo permitan</li>
                            <li>2. Horarios flexibles</li>
                            <li>3. Capacitación en SCRUM</li>
                            <li>4. Campaña de sostenibilidad</li>
                            <li>5. Capacitación en optimización de recursos</li>
                        </ul>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</section>

<section class="panel">
    <h2>Mapa Estratégico IT</h2>
    <p>
        El mapa estratégico de IT visualiza las iniciativas tecnológicas específicas 
        para alcanzar cada meta de IT, articulando las acciones clave desde aprendizaje 
        hasta la creación de valor para el cliente.
    </p>
    <figure class="diagram-block" id="diagrama-it">
        <img src="/images/MapaEstrategicoIT.png"
             alt="Mapa Estratégico IT — Balanced Scorecard"
             class="diagram-img"
             onerror="this.closest('figure').classList.add('no-img')" />
        <figcaption>
            Mapa Estratégico IT — Balanced Scorecard
            <br /><span class="diagram-path">wwwroot/images/MapaEstrategicoIT.png</span>
        </figcaption>
    </figure>
</section>

<section class="panel">
    <h3>Estrategias de IT por Dimensión</h3>
    
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Dimensión</th>
                    <th>Estrategias</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong>Aprendizaje y Crecimiento</strong></td>
                    <td>Lograr que el 100% del equipo de infraestructura complete la certificación en gestión de costos en la nube para finales del tercer trimestre de 2026.</td>
                </tr>
                <tr>
                    <td><strong>Interno/Procesos</strong></td>
                    <td>
                        <ul class="bullet-list">
                            <li>1. Asociación con proveedor de certificaciones</li>
                            <li>2. Añadir directrices de optimización de costos</li>
                            <li>3. Regular consumo de recursos</li>
                            <li>4. Establecer métricas de madurez sobre operaciones</li>
                            <li>5. Promover la obtención de certificaciones sobre procesos existentes en la organización</li>
                        </ul>
                    </td>
                </tr>
                <tr>
                    <td><strong>Financiera</strong></td>
                    <td>
                        <ul class="bullet-list">
                            <li>1. Reasignar parte del presupuesto de renovación de activos a un fondo de capacitación certificada</li>
                            <li>2. Fomentar ahorro de presupuesto</li>
                            <li>3. Incentivar contabilidad de flujo económico</li>
                            <li>4. Crear consciencia del impacto generado por altos costos</li>
                            <li>5. Eliminar costos innecesarios</li>
                        </ul>
                    </td>
                </tr>
                <tr>
                    <td><strong>Cliente / Usuario</strong></td>
                    <td>
                        <ul class="bullet-list">
                            <li>1. Aplicar descuentos limitados del precio de productos</li>
                            <li>2. Campaña de promoción</li>
                            <li>3. Sistema de suscripciones bajo licencias</li>
                            <li>4. Mayor eficacia en respuesta de soporte</li>
                            <li>5. Entregar producto con manual de usuario para evitar desaprobaciones</li>
                        </ul>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</section>

<section class="panel">
    <h2>Descargar Mapas Estratégicos Completos</h2>
    <a class="doc-link" href="/pdfs/MetasIT-7CV4-Equipo3.pdf" target="_blank">
        📄 Documento Completo - Mapas Estratégicos Corporativos e IT
    </a>
</section>
